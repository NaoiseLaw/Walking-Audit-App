// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  auditor
  coordinator
  la_admin
  system_admin
}

enum AuditStatus {
  draft
  in_progress
  completed
  reviewed
  archived
}

enum SectionName {
  footpaths
  facilities
  crossing_road
  road_user_behaviour
  safety
  look_and_feel
  school_gates
}

enum AbilityType {
  wheelchair_user
  reduced_mobility
  blind_low_vision
  deaf_hearing_loss
  cognitive_difficulties
  buggy_stroller
  young_child
  carer
  none
}

enum IssueCategory {
  footpath
  crossing
  obstacle
  safety
  lighting
  signage
  facility
  traffic
  accessibility
  maintenance
  other
}

enum IssueSeverity {
  low
  medium
  high
  critical
}

// ============================================
// USERS
// ============================================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  passwordHash            String    @map("password_hash")
  emailVerified           Boolean   @default(false) @map("email_verified")
  verificationToken       String?   @map("verification_token")
  verificationExpires     DateTime? @map("verification_expires")
  resetToken              String?   @map("reset_token")
  resetExpires            DateTime? @map("reset_expires")
  name                    String
  profilePhotoUrl         String?   @map("profile_photo_url")
  bio                     String?
  phone                   String?
  role                    UserRole  @default(auditor)
  organization            String?
  county                  String?
  language                String    @default("en")
  timezone                String    @default("Europe/Dublin")
  notificationPreferences Json      @default("{\"email\": true, \"push\": false}") @map("notification_preferences")
  auditCount              Int       @default(0) @map("audit_count")
  lastAuditDate           DateTime? @map("last_audit_date")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  lastLogin               DateTime? @map("last_login")
  deletedAt               DateTime? @map("deleted_at")
  deletedReason           String?   @map("deleted_reason")

  // Relations
  createdRoutes              Route[]            @relation("RouteCreator")
  audits                     Audit[]            @relation("AuditCoordinator")
  reviewedAudits             Audit[]            @relation("AuditReviewer")
  uploadedPhotos             Photo[]
  respondedIssues            Issue[]            @relation("IssueResponder")
  resolvedIssues             Issue[]            @relation("IssueResolver")
  verifiedIssues             Issue[]            @relation("IssueVerifier")
  respondedRecommendations   Recommendation[]   @relation("RecommendationResponder")
  implementedRecommendations Recommendation[]   @relation("RecommendationImplementer")
  verifiedRecommendations    Recommendation[]   @relation("RecommendationVerifier")
  auditLogs                  AuditLog[]
  auditParticipants          AuditParticipant[]
  syncQueue                  SyncQueue[]

  @@index([email])
  @@index([role])
  @@index([organization])
  @@index([county])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

// ============================================
// ROUTES
// ============================================

model Route {
  id                       String    @id @default(uuid())
  name                     String
  description              String?
  townCity                 String    @map("town_city")
  county                   String
  eircode                  String?
  geometry                 String // PostGIS LineString - stored as WKT
  distanceMeters           Decimal?  @map("distance_meters") @db.Decimal(10, 2)
  bbox                     String? // PostGIS Polygon
  centerPoint              String?   @map("center_point") // PostGIS Point
  avgGradientPercent       Decimal?  @map("avg_gradient_percent") @db.Decimal(4, 2)
  maxGradientPercent       Decimal?  @map("max_gradient_percent") @db.Decimal(4, 2)
  minElevationMeters       Decimal?  @map("min_elevation_meters") @db.Decimal(7, 2)
  maxElevationMeters       Decimal?  @map("max_elevation_meters") @db.Decimal(7, 2)
  permeabilityScore        Int?      @map("permeability_score")
  permeabilityNotes        String?   @map("permeability_notes")
  hasPublicTransport       Boolean   @default(false) @map("has_public_transport")
  nearestBusStopMeters     Int?      @map("nearest_bus_stop_meters")
  nearestRailStationMeters Int?      @map("nearest_rail_station_meters")
  routeType                String?   @map("route_type")
  surfaceType              String?   @map("surface_type")
  lighting                 String?
  tags                     String[]
  createdBy                String?   @map("created_by")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  auditCount               Int       @default(0) @map("audit_count")
  avgScore                 Decimal?  @map("avg_score") @db.Decimal(4, 2)
  lastAudited              DateTime? @map("last_audited")
  isPublic                 Boolean   @default(true) @map("is_public")
  isFeatured               Boolean   @default(false) @map("is_featured")
  deletedAt                DateTime? @map("deleted_at")

  // Relations
  creator      User?          @relation("RouteCreator", fields: [createdBy], references: [id])
  audits       Audit[]
  baselineData BaselineData[]

  @@index([county])
  @@index([townCity])
  @@index([createdBy])
  @@index([createdAt(sort: Desc)])
  @@index([lastAudited(sort: Desc)])
  @@index([isPublic])
  @@index([isFeatured])
  @@map("routes")
}

// ============================================
// AUDITS
// ============================================

model Audit {
  id                 String      @id @default(uuid())
  routeId            String      @map("route_id")
  coordinatorId      String      @map("coordinator_id")
  auditDate          DateTime    @map("audit_date") @db.Date
  startTime          DateTime?   @map("start_time") @db.Time
  endTime            DateTime?   @map("end_time") @db.Time
  durationMinutes    Int?        @map("duration_minutes")
  weather            String?
  temperatureCelsius Int?        @map("temperature_celsius")
  isSchoolRoute      Boolean     @default(false) @map("is_school_route")
  schoolName         String?     @map("school_name")
  peakTime           Boolean     @default(false) @map("peak_time")
  status             AuditStatus @default(draft)
  footpathsScore     Int?        @map("footpaths_score")
  facilitiesScore    Int?        @map("facilities_score")
  crossingsScore     Int?        @map("crossings_score")
  behaviourScore     Int?        @map("behaviour_score")
  safetyScore        Int?        @map("safety_score")
  lookFeelScore      Int?        @map("look_feel_score")
  schoolGatesScore   Int?        @map("school_gates_score")
  totalScore         Int?        @map("total_score")
  maxPossibleScore   Int?        @map("max_possible_score")
  normalizedScore    Decimal?    @map("normalized_score") @db.Decimal(3, 2)
  walkabilityRating  String?     @map("walkability_rating")
  enjoyabilityRating Int?        @map("enjoyability_rating")
  wouldWalkMore      Boolean?    @map("would_walk_more")
  wouldRecommend     Boolean?    @map("would_recommend")
  likedMost          String?     @map("liked_most")
  dislikedMost       String?     @map("disliked_most")
  additionalComments String?     @map("additional_comments")
  reportPdfUrl       String?     @map("report_pdf_url")
  reportGeneratedAt  DateTime?   @map("report_generated_at")
  reportVersion      Int         @default(1) @map("report_version")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  completedAt        DateTime?   @map("completed_at")
  reviewedAt         DateTime?   @map("reviewed_at")
  reviewedBy         String?     @map("reviewed_by")
  version            Int         @default(1)
  deletedAt          DateTime?   @map("deleted_at")

  // Relations
  route           Route              @relation(fields: [routeId], references: [id])
  coordinator     User               @relation("AuditCoordinator", fields: [coordinatorId], references: [id])
  reviewer        User?              @relation("AuditReviewer", fields: [reviewedBy], references: [id])
  participants    AuditParticipant[]
  sections        AuditSection[]
  issues          Issue[]
  photos          Photo[]
  recommendations Recommendation[]
  reportMetrics   ReportMetrics?
  baselineData    BaselineData[]
  auditLogs       AuditLog[]

  @@index([routeId])
  @@index([coordinatorId])
  @@index([status])
  @@index([auditDate(sort: Desc)])
  @@index([completedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([walkabilityRating])
  @@index([isSchoolRoute])
  @@index([routeId, auditDate(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("audits")
}

// ============================================
// AUDIT PARTICIPANTS
// ============================================

model AuditParticipant {
  id             String   @id @default(uuid())
  auditId        String   @map("audit_id")
  userId         String?  @map("user_id")
  ageGroup       String   @map("age_group")
  sex            String?
  participatedAt DateTime @default(now()) @map("participated_at")

  // Relations
  audit          Audit                @relation(fields: [auditId], references: [id], onDelete: Cascade)
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  abilities      ParticipantAbility[]
  reportedIssues Issue[]              @relation("IssueReporter")

  @@unique([auditId, userId])
  @@index([auditId])
  @@index([userId])
  @@index([ageGroup])
  @@map("audit_participants")
}

model ParticipantAbility {
  participantId String      @map("participant_id")
  ability       AbilityType

  // Relations
  participant AuditParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@id([participantId, ability])
  @@index([participantId])
  @@index([ability])
  @@map("participant_abilities")
}

// ============================================
// AUDIT SECTIONS
// ============================================

model AuditSection {
  id           String      @id @default(uuid())
  auditId      String      @map("audit_id")
  section      SectionName
  score        Int
  responses    Json        @default("{}")
  comments     String?
  problemAreas String[]    @map("problem_areas")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, section])
  @@index([auditId])
  @@index([section])
  @@index([score])
  @@map("audit_sections")
}

// ============================================
// ISSUES
// ============================================

model Issue {
  id                     String        @id @default(uuid())
  auditId                String        @map("audit_id")
  section                SectionName
  location               String // PostGIS Point - stored as WKT
  locationDescription    String?       @map("location_description")
  locationAccuracyMeters Int?          @map("location_accuracy_meters")
  category               IssueCategory
  severity               IssueSeverity @default(medium)
  title                  String
  description            String?
  reportedBy             String?       @map("reported_by")
  laAcknowledged         Boolean       @default(false) @map("la_acknowledged")
  laAcknowledgedAt       DateTime?     @map("la_acknowledged_at")
  laAcknowledgedBy       String?       @map("la_acknowledged_by")
  laResponse             String?       @map("la_response")
  laStatus               String        @default("open") @map("la_status")
  resolvedAt             DateTime?     @map("resolved_at")
  resolutionNotes        String?       @map("resolution_notes")
  resolvedBy             String?       @map("resolved_by")
  verified               Boolean       @default(false)
  verifiedAt             DateTime?     @map("verified_at")
  verifiedBy             String?       @map("verified_by")
  estimatedCostEuros     Decimal?      @map("estimated_cost_euros") @db.Decimal(10, 2)
  actualCostEuros        Decimal?      @map("actual_cost_euros") @db.Decimal(10, 2)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")

  // Relations
  audit          Audit             @relation(fields: [auditId], references: [id], onDelete: Cascade)
  reporter       AuditParticipant? @relation("IssueReporter", fields: [reportedBy], references: [id], onDelete: SetNull)
  acknowledgedBy User?             @relation("IssueResponder", fields: [laAcknowledgedBy], references: [id])
  resolver       User?             @relation("IssueResolver", fields: [resolvedBy], references: [id])
  verifier       User?             @relation("IssueVerifier", fields: [verifiedBy], references: [id])
  photos         Photo[]

  @@index([auditId])
  @@index([section])
  @@index([category])
  @@index([severity])
  @@index([laStatus])
  @@index([createdAt(sort: Desc)])
  @@index([resolvedAt])
  @@index([severity, laStatus])
  @@index([auditId, severity])
  @@map("issues")
}

// ============================================
// PHOTOS
// ============================================

model Photo {
  id                     String    @id @default(uuid())
  issueId                String?   @map("issue_id")
  auditId                String    @map("audit_id")
  url                    String
  thumbnailUrl           String?   @map("thumbnail_url")
  filename               String?
  originalFilename       String?   @map("original_filename")
  fileSizeKb             Int?      @map("file_size_kb")
  mimeType               String?   @map("mime_type")
  widthPx                Int?      @map("width_px")
  heightPx               Int?      @map("height_px")
  location               String? // PostGIS Point
  locationAccuracyMeters Int?      @map("location_accuracy_meters")
  locationSource         String?   @map("location_source")
  takenAt                DateTime? @map("taken_at")
  cameraMake             String?   @map("camera_make")
  cameraModel            String?   @map("camera_model")
  focalLengthMm          Decimal?  @map("focal_length_mm") @db.Decimal(5, 2)
  aperture               String?
  iso                    Int?
  exifData               Json?     @map("exif_data")
  processed              Boolean   @default(false)
  compressionApplied     Boolean   @default(false) @map("compression_applied")
  blurFaces              Boolean   @default(false) @map("blur_faces")
  uploadedBy             String?   @map("uploaded_by")
  uploadedAt             DateTime  @default(now()) @map("uploaded_at")
  deletedAt              DateTime? @map("deleted_at")

  // Relations
  issue    Issue? @relation(fields: [issueId], references: [id], onDelete: Cascade)
  audit    Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  uploader User?  @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([issueId])
  @@index([auditId])
  @@index([uploadedAt(sort: Desc)])
  @@index([uploadedBy])
  @@index([takenAt])
  @@map("photos")
}

// ============================================
// RECOMMENDATIONS
// ============================================

model Recommendation {
  id                      String    @id @default(uuid())
  auditId                 String    @map("audit_id")
  priority                Int
  title                   String
  description             String
  rationale               String?
  relatedIssueIds         String[]  @default([]) @map("related_issue_ids")
  issueCount              Int       @default(0) @map("issue_count")
  estimatedCostEuros      Decimal?  @map("estimated_cost_euros") @db.Decimal(10, 2)
  estimatedTimeframe      String?   @map("estimated_timeframe")
  complexity              String?
  category                String?
  laStatus                String    @default("pending") @map("la_status")
  laResponse              String?   @map("la_response")
  laResponseDate          DateTime? @map("la_response_date")
  laRespondedBy           String?   @map("la_responded_by")
  rejectionReason         String?   @map("rejection_reason")
  implemented             Boolean   @default(false)
  implementedAt           DateTime? @map("implemented_at")
  implementationNotes     String?   @map("implementation_notes")
  implementationCostEuros Decimal?  @map("implementation_cost_euros") @db.Decimal(10, 2)
  implementedBy           String?   @map("implemented_by")
  verified                Boolean   @default(false)
  verifiedAt              DateTime? @map("verified_at")
  verifiedBy              String?   @map("verified_by")
  verificationNotes       String?   @map("verification_notes")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  // Relations
  audit       Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  responder   User? @relation("RecommendationResponder", fields: [laRespondedBy], references: [id])
  implementer User? @relation("RecommendationImplementer", fields: [implementedBy], references: [id])
  verifier    User? @relation("RecommendationVerifier", fields: [verifiedBy], references: [id])

  @@index([auditId])
  @@index([laStatus])
  @@index([priority])
  @@index([category])
  @@index([implemented])
  @@index([createdAt(sort: Desc)])
  @@index([auditId, priority])
  @@index([laStatus, createdAt(sort: Desc)])
  @@map("recommendations")
}

// ============================================
// BASELINE DATA
// ============================================

model BaselineData {
  id                          String    @id @default(uuid())
  routeId                     String    @map("route_id")
  auditId                     String?   @map("audit_id")
  location                    String? // PostGIS Point
  avgTrafficVolume            Int?      @map("avg_traffic_volume")
  peakTrafficVolume           Int?      @map("peak_traffic_volume")
  offPeakTrafficVolume        Int?      @map("off_peak_traffic_volume")
  avgTrafficSpeedKmh          Decimal?  @map("avg_traffic_speed_kmh") @db.Decimal(5, 2)
  trafficDataDate             DateTime? @map("traffic_data_date") @db.Date
  airQualityIndex             Int?      @map("air_quality_index")
  pm25Concentration           Decimal?  @map("pm25_concentration") @db.Decimal(6, 2)
  pm10Concentration           Decimal?  @map("pm10_concentration") @db.Decimal(6, 2)
  no2Concentration            Decimal?  @map("no2_concentration") @db.Decimal(6, 2)
  o3Concentration             Decimal?  @map("o3_concentration") @db.Decimal(6, 2)
  airQualityDate              DateTime? @map("air_quality_date") @db.Date
  noiseLevelDb                Decimal?  @map("noise_level_db") @db.Decimal(5, 2)
  noiseSource                 String?   @map("noise_source")
  noiseMeasurementDate        DateTime? @map("noise_measurement_date") @db.Date
  intersectionDensity         Decimal?  @map("intersection_density") @db.Decimal(10, 4)
  residentialDensity          Int?      @map("residential_density")
  commercialDensity           Int?      @map("commercial_density")
  landUseMix                  Decimal?  @map("land_use_mix") @db.Decimal(3, 2)
  busStopsWithin400m          Int?      @map("bus_stops_within_400m")
  busRoutesCount              Int?      @map("bus_routes_count")
  railStationsWithin800m      Int?      @map("rail_stations_within_800m")
  bikeShareStationsWithin500m Int?      @map("bike_share_stations_within_500m")
  pedestrianFlowCount         Int?      @map("pedestrian_flow_count")
  pedestrianFlowPeakTime      DateTime? @map("pedestrian_flow_peak_time") @db.Time
  dataSource                  String    @map("data_source")
  dataVersion                 String?   @map("data_version")
  dataDate                    DateTime  @map("data_date") @db.Date
  collectedAt                 DateTime  @default(now()) @map("collected_at")
  collectionMethod            String?   @map("collection_method")
  accuracyLevel               String?   @map("accuracy_level")
  notes                       String?
  version                     Int       @default(1)

  // Relations
  route Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  audit Audit? @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([auditId])
  @@index([dataDate(sort: Desc)])
  @@index([dataSource])
  @@map("baseline_data")
}

// ============================================
// REPORT METRICS
// ============================================

model ReportMetrics {
  id                     String         @id @default(uuid())
  auditId                String         @unique @map("audit_id")
  footpathsScore         Decimal?       @map("footpaths_score") @db.Decimal(3, 2)
  facilitiesScore        Decimal?       @map("facilities_score") @db.Decimal(3, 2)
  crossingsScore         Decimal?       @map("crossings_score") @db.Decimal(3, 2)
  behaviourScore         Decimal?       @map("behaviour_score") @db.Decimal(3, 2)
  safetyScore            Decimal?       @map("safety_score") @db.Decimal(3, 2)
  lookFeelScore          Decimal?       @map("look_feel_score") @db.Decimal(3, 2)
  schoolGatesScore       Decimal?       @map("school_gates_score") @db.Decimal(3, 2)
  overallScore           Decimal?       @map("overall_score") @db.Decimal(3, 2)
  totalIssues            Int            @default(0) @map("total_issues")
  criticalIssues         Int            @default(0) @map("critical_issues")
  highIssues             Int            @default(0) @map("high_issues")
  mediumIssues           Int            @default(0) @map("medium_issues")
  lowIssues              Int            @default(0) @map("low_issues")
  totalPhotos            Int            @default(0) @map("total_photos")
  totalRecommendations   Int            @default(0) @map("total_recommendations")
  totalParticipants      Int            @default(0) @map("total_participants")
  footpathIssues         Int            @default(0) @map("footpath_issues")
  crossingIssues         Int            @default(0) @map("crossing_issues")
  safetyIssues           Int            @default(0) @map("safety_issues")
  lightingIssues         Int            @default(0) @map("lighting_issues")
  accessibilityIssues    Int            @default(0) @map("accessibility_issues")
  countyAvgScore         Decimal?       @map("county_avg_score") @db.Decimal(4, 2)
  nationalAvgScore       Decimal?       @map("national_avg_score") @db.Decimal(4, 2)
  similarRoutesAvgScore  Decimal?       @map("similar_routes_avg_score") @db.Decimal(4, 2)
  percentileRank         Int?           @map("percentile_rank")
  rankWithinCounty       Int?           @map("rank_within_county")
  totalAuditsInCounty    Int?           @map("total_audits_in_county")
  topIssueCategory1      IssueCategory? @map("top_issue_category_1")
  topIssueCategory1Count Int?           @map("top_issue_category_1_count")
  topIssueCategory2      IssueCategory? @map("top_issue_category_2")
  topIssueCategory2Count Int?           @map("top_issue_category_2_count")
  topIssueCategory3      IssueCategory? @map("top_issue_category_3")
  topIssueCategory3Count Int?           @map("top_issue_category_3_count")
  topStrength1           SectionName?   @map("top_strength_1")
  topStrength1Score      Decimal?       @map("top_strength_1_score") @db.Decimal(3, 2)
  topStrength2           SectionName?   @map("top_strength_2")
  topStrength2Score      Decimal?       @map("top_strength_2_score") @db.Decimal(3, 2)
  topStrength3           SectionName?   @map("top_strength_3")
  topStrength3Score      Decimal?       @map("top_strength_3_score") @db.Decimal(3, 2)
  topWeakness1           SectionName?   @map("top_weakness_1")
  topWeakness1Score      Decimal?       @map("top_weakness_1_score") @db.Decimal(3, 2)
  topWeakness2           SectionName?   @map("top_weakness_2")
  topWeakness2Score      Decimal?       @map("top_weakness_2_score") @db.Decimal(3, 2)
  topWeakness3           SectionName?   @map("top_weakness_3")
  topWeakness3Score      Decimal?       @map("top_weakness_3_score") @db.Decimal(3, 2)
  generatedAt            DateTime       @default(now()) @map("generated_at")
  cacheValidUntil        DateTime?      @map("cache_valid_until")
  needsRegeneration      Boolean        @default(false) @map("needs_regeneration")

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([generatedAt(sort: Desc)])
  @@index([needsRegeneration])
  @@map("report_metrics")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id            String   @id @default(uuid())
  auditId       String?  @map("audit_id")
  userId        String?  @map("user_id")
  action        String
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id")
  details       Json     @default("{}")
  oldValues     Json?    @map("old_values")
  newValues     Json?    @map("new_values")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  requestMethod String?  @map("request_method")
  requestPath   String?  @map("request_path")
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  audit Audit? @relation(fields: [auditId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([auditId])
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@index([ipAddress])
  @@map("audit_log")
}

// ============================================
// SYNC QUEUE
// ============================================

model SyncQueue {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  entityType    String    @map("entity_type")
  entityId      String    @map("entity_id")
  operation     String
  payload       Json
  status        String    @default("pending")
  priority      String    @default("normal")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3) @map("max_attempts")
  lastError     String?   @map("last_error")
  lastAttemptAt DateTime? @map("last_attempt_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")
  completedAt   DateTime? @map("completed_at")
  deviceInfo    Json?     @map("device_info")
  appVersion    String?   @map("app_version")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([status, priority(sort: Desc), createdAt])
  @@map("sync_queue")
}

// ============================================
// EMAIL QUEUE
// ============================================

model EmailQueue {
  id                String    @id @default(uuid())
  recipientEmail    String    @map("recipient_email")
  recipientName     String?   @map("recipient_name")
  recipientUserId   String?   @map("recipient_user_id")
  subject           String
  bodyText          String?   @map("body_text")
  bodyHtml          String?   @map("body_html")
  templateName      String?   @map("template_name")
  templateData      Json?     @map("template_data")
  attachments       Json?
  emailType         String?   @map("email_type")
  status            String    @default("pending")
  sentAt            DateTime? @map("sent_at")
  attempts          Int       @default(0)
  maxAttempts       Int       @default(3) @map("max_attempts")
  lastError         String?   @map("last_error")
  lastAttemptAt     DateTime? @map("last_attempt_at")
  sendgridMessageId String?   @map("sendgrid_message_id")
  sendgridResponse  Json?     @map("sendgrid_response")
  priority          String    @default("normal")
  sendAfter         DateTime? @map("send_after")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@index([sendAfter])
  @@index([priority, createdAt])
  @@index([emailType])
  @@index([recipientEmail])
  @@index([status, priority(sort: Desc), sendAfter, createdAt])
  @@map("email_queue")
}
